# Supreme Transfer - Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/supreme_transfer

# Stripe Keys (get from Stripe dashboard)
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_REAL_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_REAL_KEY
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_32_char_encryption_key_here

# App URL (used for email links)
APP_URL=https://supremetransfer.bluesapps.com

# Email (SMTP via Mailgun)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=invite@bluestoneapps.com
SMTP_PASS=your_smtp_password_here
